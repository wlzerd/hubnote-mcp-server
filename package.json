{
  "name": "@hubnote-mcp/server",
  "version": "0.1.1",
  "description": "MCP server for hubNote — connect Claude Desktop / Cursor / Codex to your hubNote workspaces.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hubnote-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "embed-help": "tsx scripts/embed-help.ts",
    "build": "pnpm run embed-help && tsc",
    "dev": "pnpm run embed-help && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "pnpm run embed-help && tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hubnote",
    "claude",
    "ai",
    "notion-alternative"
  ],
  "homepage": "https://notion.discof.com/help/mcp-integration",
  "repository": {
    "type": "git",
    "url": "https://github.com/wlzerd/hubnote-mcp-server.git"
  }
}
